{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "lib": ["es2022"],
    "paths": {
      "@2d6mcp/shared": ["../../packages/shared/src"],
      "@2d6mcp/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
