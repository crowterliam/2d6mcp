# --- BYOD Mode (Bring Your Own Data) ---
# Set to "true" to enable local file ingestion for personal, non-commercial use.
# By enabling this, you confirm you are the legal owner of the imported files
# or hold a valid license to use them. This tool is provided strictly for
# personal, non-commercial automation and referencing.
AGREE_NON_COMMERCIAL_USE="false"

# Absolute path to your local directory containing RPG source files
# (PDF, .txt, .md). Only read when AGREE_NON_COMMERCIAL_USE is "true".
BYOD_PATH=""

# Path to a custom OGL SQLite database (optional).
# Defaults to the bundled Cepheus Engine SRD database at data/ogl/cepheus.db
OGL_DB_PATH=""
